# =============================================================================
# Almacenamiento S3 — Ciclo 2 Fase 2.1
# Copiar a .env y ajustar valores. No commitear .env con credenciales reales.
# =============================================================================

# --- MinIO (desarrollo local — docker compose up minio) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# --- AWS S3 (demo / producción — perfil Spring: demo o prod) ---
AWS_S3_BUCKET=workflow-docs-demo
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Dejar vacío para AWS S3 real. Solo MinIO/local: http://localhost:9000
AWS_S3_ENDPOINT=
